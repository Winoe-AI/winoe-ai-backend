{
  "$defs": {
    "ScenarioRubric": {
      "additionalProperties": false,
      "description": "Structured rubric contract for scenario generation.",
      "properties": {
        "dayWeights": {
          "$ref": "#/$defs/ScenarioRubricDayWeights"
        },
    "dimensions": {
      "items": {
        "$ref": "#/$defs/ScenarioRubricDimension"
      },
      "maxItems": 9,
      "minItems": 7,
      "title": "Dimensions",
      "type": "array"
    },
        "summary": {
          "maxLength": 4000,
          "minLength": 1,
          "title": "Summary",
          "type": "string"
        }
      },
      "required": [
        "summary",
        "dayWeights",
        "dimensions"
      ],
      "title": "ScenarioRubric",
      "type": "object"
    },
    "ScenarioRubricDayWeights": {
      "additionalProperties": false,
      "description": "Fixed 5-day weighting contract for generated scenario rubrics.",
      "properties": {
        "1": {
          "maximum": 100,
          "minimum": 0,
          "title": "1",
          "type": "integer"
        },
        "2": {
          "maximum": 100,
          "minimum": 0,
          "title": "2",
          "type": "integer"
        },
        "3": {
          "maximum": 100,
          "minimum": 0,
          "title": "3",
          "type": "integer"
        },
        "4": {
          "maximum": 100,
          "minimum": 0,
          "title": "4",
          "type": "integer"
        },
        "5": {
          "maximum": 100,
          "minimum": 0,
          "title": "5",
          "type": "integer"
        }
      },
      "required": [
        "1",
        "2",
        "3",
        "4",
        "5"
      ],
      "title": "ScenarioRubricDayWeights",
      "type": "object"
    },
    "ScenarioRubricDimension": {
      "additionalProperties": false,
      "description": "Named rubric dimension with explanation and relative weight.",
      "properties": {
        "description": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "name": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Name",
          "type": "string"
        },
        "weight": {
          "maximum": 100,
          "minimum": 0,
          "title": "Weight",
          "type": "integer"
        }
      },
      "required": [
        "name",
        "weight",
        "description"
      ],
      "title": "ScenarioRubricDimension",
      "type": "object"
    },
    "ScenarioTaskPrompt": {
      "additionalProperties": false,
      "description": "Per-day scenario prompt payload that maps onto seeded task rows.",
      "properties": {
        "dayIndex": {
          "maximum": 5,
          "minimum": 1,
          "title": "Dayindex",
          "type": "integer"
        },
        "description": {
          "maxLength": 10000,
          "minLength": 1,
          "title": "Description",
          "type": "string"
        },
        "title": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Title",
          "type": "string"
        }
      },
      "required": [
        "dayIndex",
        "title",
        "description"
      ],
      "title": "ScenarioTaskPrompt",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Strict output contract for the prestart creator agent.",
  "properties": {
    "project_brief_md": {
      "maxLength": 40000,
      "minLength": 1,
      "title": "Project Brief Md",
      "type": "string"
    },
    "rubric_json": {
      "$ref": "#/$defs/ScenarioRubric"
    },
    "storyline_md": {
      "maxLength": 40000,
      "minLength": 1,
      "title": "Storyline Md",
      "type": "string"
    },
    "task_prompts_json": {
      "items": {
        "$ref": "#/$defs/ScenarioTaskPrompt"
      },
      "maxItems": 5,
      "minItems": 5,
      "title": "Task Prompts Json",
      "type": "array"
    }
  },
  "required": [
    "storyline_md",
    "task_prompts_json",
    "project_brief_md",
    "rubric_json"
  ],
  "title": "ScenarioGenerationOutput",
  "type": "object"
}
