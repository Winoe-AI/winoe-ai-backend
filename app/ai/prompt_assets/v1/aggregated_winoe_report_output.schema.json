{
  "$defs": {
    "AggregatorDayScore": {
      "additionalProperties": false,
      "description": "Aggregator-facing summary for a single day.",
      "properties": {
        "dayIndex": {
          "maximum": 5,
          "minimum": 1,
          "title": "Dayindex",
          "type": "integer"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidencePointer"
          },
          "title": "Evidence",
          "type": "array"
        },
        "reason": {
          "anyOf": [
            {
              "maxLength": 4000,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Reason"
        },
        "rubricBreakdown": {
          "anyOf": [
            {
              "additionalProperties": true,
              "type": "object"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rubricbreakdown"
        },
        "score": {
          "anyOf": [
            {
              "maximum": 1.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Score"
        },
        "status": {
          "enum": [
            "scored",
            "human_review_required"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "dayIndex",
        "status"
      ],
      "title": "AggregatorDayScore",
      "type": "object"
    },
    "EvidencePointer": {
      "additionalProperties": false,
      "description": "Evidence reference returned by reviewer models.",
      "properties": {
        "dayIndex": {
          "maximum": 5,
          "minimum": 1,
          "title": "Dayindex",
          "type": "integer"
        },
        "kind": {
          "enum": [
            "submission",
            "diff",
            "transcript",
            "tests",
            "rubric"
          ],
          "title": "Kind",
          "type": "string"
        },
        "quote": {
          "anyOf": [
            {
              "maxLength": 1500,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quote"
        },
        "ref": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Ref",
          "type": "string"
        }
      },
      "required": [
        "kind",
        "ref",
        "dayIndex"
      ],
      "title": "EvidencePointer",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Strict output contract for the winoe-report aggregator agent.",
  "properties": {
    "calibrationText": {
      "maxLength": 4000,
      "minLength": 1,
      "title": "Calibrationtext",
      "type": "string"
    },
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "dayScores": {
      "items": {
        "$ref": "#/$defs/AggregatorDayScore"
      },
      "maxItems": 5,
      "minItems": 1,
      "title": "Dayscores",
      "type": "array"
    },
    "overallWinoeScore": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Overallwinoescore",
      "type": "number"
    },
    "recommendation": {
      "enum": [
        "strong_signal",
        "positive_signal",
        "mixed_signal",
        "limited_signal"
      ],
      "title": "Recommendation",
      "type": "string"
    },
    "risks": {
      "items": {
        "type": "string"
      },
      "maxItems": 10,
      "title": "Risks",
      "type": "array"
    },
    "strengths": {
      "items": {
        "type": "string"
      },
      "maxItems": 10,
      "title": "Strengths",
      "type": "array"
    }
  },
  "required": [
    "overallWinoeScore",
    "recommendation",
    "confidence",
    "dayScores",
    "calibrationText"
  ],
  "title": "AggregatedWinoeReportOutput",
  "type": "object"
}
