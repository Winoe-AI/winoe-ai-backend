# Sample environment configuration for local/dev.
# Copy to `.env` and fill in real values where needed.

# -----------------------------
# Core
# -----------------------------
TENON_ENV=local
TENON_API_PREFIX=/api
DEV_AUTH_BYPASS=0
TENON_DEV_AUTH_BYPASS=0
# DEV_AUTH_BYPASS/TENON_DEV_AUTH_BYPASS are local-only; app refuses startup
# in non-local envs when enabled.

TENON_RATE_LIMIT_ENABLED=0
TENON_MAX_REQUEST_BODY_BYTES=1048576
TENON_TRUSTED_PROXY_CIDRS=[]

TENON_DEBUG_PERF=0
TENON_PERF_SPANS_ENABLED=0
TENON_PERF_SQL_FINGERPRINTS_ENABLED=0
TENON_PERF_SPAN_SAMPLE_RATE=1.0
TENON_SCHEDULE_DAY_WINDOW_OVERRIDES_ENABLED=0

# -----------------------------
# Demo mode / admin allowlists
# -----------------------------
TENON_DEMO_MODE=0
TENON_SCENARIO_DEMO_MODE=0
TENON_DEMO_ADMIN_ALLOWLIST_EMAILS=[]
TENON_DEMO_ADMIN_ALLOWLIST_SUBJECTS=[]
TENON_DEMO_ADMIN_ALLOWLIST_RECRUITER_IDS=[]
TENON_DEMO_ADMIN_JOB_STALE_SECONDS=900

# -----------------------------
# Database
# -----------------------------
TENON_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/tenon
TENON_DATABASE_URL_SYNC=postgresql://user:pass@localhost:5432/tenon

# -----------------------------
# Auth0 (API / JWT verification)
# -----------------------------
TENON_AUTH0_DOMAIN=example.auth0.com
TENON_AUTH0_ISSUER=https://example.auth0.com/
TENON_AUTH0_JWKS_URL=https://example.auth0.com/.well-known/jwks.json
TENON_AUTH0_API_AUDIENCE=https://tenon.ai/api
TENON_AUTH0_ALGORITHMS=RS256
TENON_AUTH0_JWKS_CACHE_TTL_SECONDS=3600
TENON_AUTH0_LEEWAY_SECONDS=60
TENON_AUTH0_CLAIM_NAMESPACE=https://tenon.ai
TENON_AUTH0_EMAIL_CLAIM=https://tenon.ai/email
TENON_AUTH0_PERMISSIONS_CLAIM=https://tenon.ai/permissions
TENON_AUTH0_ROLES_CLAIM=https://tenon.ai/roles

# -----------------------------
# CORS
# -----------------------------
TENON_CORS_ALLOW_ORIGINS=["http://localhost:3000"]
TENON_CORS_ALLOW_ORIGIN_REGEX=
# In non-local environments, CORS allowlist must be explicit and cannot use wildcards.

# -----------------------------
# CSRF (cookie-authenticated BFF routes)
# -----------------------------
# Allowed origins for Origin/Referer checks. If empty, falls back to TENON_CORS_ALLOW_ORIGINS.
TENON_CSRF_ALLOWED_ORIGINS=["http://localhost:3000"]
# Path prefixes where cookie-authenticated state-changing methods are CSRF-protected.
# If unset, defaults to TENON_API_PREFIX.
TENON_CSRF_PROTECTED_PATH_PREFIXES=["/api"]

# -----------------------------
# Frontend base URL (invite links)
# -----------------------------
TENON_CANDIDATE_PORTAL_BASE_URL=http://localhost:3000

# -----------------------------
# GitHub-native
# -----------------------------
TENON_GITHUB_API_BASE=https://api.github.com
TENON_GITHUB_ORG=
TENON_GITHUB_TEMPLATE_OWNER=
TENON_GITHUB_REPO_PREFIX=tenon-ws-
TENON_GITHUB_ACTIONS_WORKFLOW_FILE=tenon-ci.yml
TENON_GITHUB_CLEANUP_ENABLED=false
TENON_WORKSPACE_RETENTION_DAYS=30
TENON_WORKSPACE_CLEANUP_MODE=archive
TENON_WORKSPACE_DELETE_ENABLED=false
TENON_GITHUB_TOKEN=
TENON_GITHUB_WEBHOOK_SECRET=
TENON_GITHUB_WEBHOOK_MAX_BODY_BYTES=262144

# Scenario generation credentials (optional; fallback mode is used if unset)
TENON_OPENAI_API_KEY=
TENON_ANTHROPIC_API_KEY=

# -----------------------------
# Media / privacy controls
# -----------------------------
TENON_MEDIA_STORAGE_PROVIDER=fake
TENON_MEDIA_S3_ENDPOINT=
TENON_MEDIA_S3_REGION=us-east-1
TENON_MEDIA_S3_BUCKET=
TENON_MEDIA_S3_ACCESS_KEY_ID=
TENON_MEDIA_S3_SECRET_ACCESS_KEY=
TENON_MEDIA_S3_SESSION_TOKEN=
TENON_MEDIA_S3_USE_PATH_STYLE=true

TENON_SIGNED_URL_EXPIRY_SECONDS=900
TENON_MEDIA_SIGNED_URL_EXPIRES_SECONDS=900
TENON_MEDIA_SIGNED_URL_MIN_SECONDS=60
TENON_MEDIA_SIGNED_URL_MAX_SECONDS=1800

TENON_MEDIA_RETENTION_DAYS=45
TENON_MEDIA_DELETE_ENABLED=true
TENON_MEDIA_MAX_UPLOAD_BYTES=104857600
TENON_MEDIA_ALLOWED_CONTENT_TYPES=["video/mp4","video/webm","video/quicktime"]
TENON_MEDIA_ALLOWED_EXTENSIONS=["mp4","webm","mov"]

# -----------------------------
# Email
# -----------------------------
TENON_EMAIL_PROVIDER=console
TENON_EMAIL_FROM="Tenon <notifications@tenon.com>"
TENON_RESEND_API_KEY=
SENDGRID_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true

# -----------------------------
# Admin
# -----------------------------
TENON_ADMIN_API_KEY=
